<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.PersonalMorningAlarm" parent="Theme.Material3.DayNight.NoActionBar" />

    <!-- Nuclear dismissal challenge cards -->
    <style name="NuclearCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:layout_marginTop">20dp</item>
        <item name="android:padding">16dp</item>
        <item name="android:background">#22FFFFFF</item>
    </style>

    <style name="NuclearCardHeader">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="NuclearStatus">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginEnd">12dp</item>
        <item name="android:text">○</item>
        <item name="android:textColor">#FFBBBBBB</item>
        <item name="android:textSize">24sp</item>
    </style>

    <style name="NuclearCardTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textAppearance">?attr/textAppearanceTitleMedium</item>
    </style>

    <style name="NuclearInput">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textColorHint">#FF888888</item>
        <item name="android:backgroundTint">@android:color/white</item>
    </style>
</resources>
