<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.personalmorningalarm.ui.HomeFragment"
        android:label="@string/title_home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_today"
            app:destination="@id/todayFragment" />
    </fragment>

    <fragment
        android:id="@+id/todayFragment"
        android:name="com.personalmorningalarm.ui.TodayFragment"
        android:label="@string/today_screen_title"
        tools:layout="@layout/fragment_today" />

    <fragment
        android:id="@+id/statisticsFragment"
        android:name="com.personalmorningalarm.ui.StatisticsFragment"
        android:label="@string/title_statistics"
        tools:layout="@layout/fragment_statistics" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.personalmorningalarm.ui.SettingsFragment"
        android:label="@string/title_settings"
        tools:layout="@layout/fragment_settings">
        <action
            android:id="@+id/action_settings_to_nfcTags"
            app:destination="@id/nfcTagsFragment" />
        <action
            android:id="@+id/action_settings_to_quotes"
            app:destination="@id/quoteManagementFragment" />
        <action
            android:id="@+id/action_settings_to_routines"
            app:destination="@id/stretchRoutinesFragment" />
    </fragment>

    <fragment
        android:id="@+id/nfcTagsFragment"
        android:name="com.personalmorningalarm.ui.NfcTagsFragment"
        android:label="@string/nfc_tags_screen_title"
        tools:layout="@layout/fragment_nfc_tags" />

    <fragment
        android:id="@+id/quoteManagementFragment"
        android:name="com.personalmorningalarm.ui.QuoteManagementFragment"
        android:label="@string/quote_management_title"
        tools:layout="@layout/fragment_quote_management" />

    <fragment
        android:id="@+id/stretchRoutinesFragment"
        android:name="com.personalmorningalarm.ui.StretchRoutinesFragment"
        android:label="@string/routines_title"
        tools:layout="@layout/fragment_stretch_routines">
        <action
            android:id="@+id/action_routines_to_edit"
            app:destination="@id/routineEditFragment" />
    </fragment>

    <fragment
        android:id="@+id/routineEditFragment"
        android:name="com.personalmorningalarm.ui.RoutineEditFragment"
        android:label="@string/routine_edit_title"
        tools:layout="@layout/fragment_routine_edit">
        <argument
            android:name="routineId"
            app:argType="long" />
    </fragment>

</navigation>
