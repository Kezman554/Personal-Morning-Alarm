<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/nfc_section_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nfc_section_title"
            android:textAppearance="?attr/textAppearanceHeadlineSmall" />

        <Button
            android:id="@+id/btn_manage_tags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/manage_nfc_tags" />

        <TextView
            android:id="@+id/content_section_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/content_section_title"
            android:textAppearance="?attr/textAppearanceHeadlineSmall" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_quote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/toggle_quote" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_stretch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/toggle_stretch" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_placeholder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/toggle_placeholder" />

    </LinearLayout>

</ScrollView>
