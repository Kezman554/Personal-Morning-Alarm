<?xml version="1.0" encoding="utf-8"?>
<!-- One inbox capture. No background selector and no click target: the inbox is
     read-only from the phone — triage happens in a vault session. -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="8dp">

    <TextView
        android:id="@+id/tv_inbox_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceTitleSmall"
        tools:text="Morningsync restructure ideas" />

    <TextView
        android:id="@+id/tv_inbox_captured"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceLabelSmall"
        android:visibility="gone"
        tools:text="17 Jul, 13:56"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/tv_inbox_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:lineSpacingMultiplier="1.15"
        android:maxLines="3"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:visibility="gone"
        tools:text="Possible next phase / identity shift, no decisions yet…"
        tools:visibility="visible" />

    <!-- Only on captures still waiting in the offline queue. -->
    <TextView
        android:id="@+id/tv_inbox_pending"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/chalkboard_item_pending"
        android:textAppearance="?attr/textAppearanceLabelMedium"
        android:textColor="?attr/colorPrimary"
        android:textStyle="italic"
        android:visibility="gone"
        tools:visibility="visible" />

</LinearLayout>
