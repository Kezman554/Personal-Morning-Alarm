<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipe_refresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- NestedScrollView, not ScrollView: a wrap_content RecyclerView inside a
         plain ScrollView gets mis-measured and truncates the to-do list. -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Today's Schedule. Hidden wholesale when a tile asked for the to-do only. -->
            <LinearLayout
                android:id="@+id/section_schedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/today_schedule_section"
                    android:textAppearance="?attr/textAppearanceHeadlineSmall" />

                <!-- Per-section status (e.g. showing a cached copy) -->
                <TextView
                    android:id="@+id/tv_schedule_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textAppearance="?attr/textAppearanceLabelMedium"
                    android:visibility="gone"
                    tools:text="Saved copy — Alfred unreachable"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/tv_schedule_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingMultiplier="1.15"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    tools:text="Morning\n• Gym" />

            </LinearLayout>

            <View
                android:id="@+id/section_divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="24dp"
                android:background="?attr/colorOutlineVariant" />

            <!-- Rolling To-Do. Hidden wholesale when a tile asked for the schedule only. -->
            <LinearLayout
                android:id="@+id/section_chalkboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/today_chalkboard_section"
                    android:textAppearance="?attr/textAppearanceHeadlineSmall" />

                <TextView
                    android:id="@+id/tv_chalkboard_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textAppearance="?attr/textAppearanceLabelMedium"
                    android:visibility="gone"
                    tools:text="Saved copy — Alfred unreachable"
                    tools:visibility="visible" />

                <!-- Offline queue count — "2 changes waiting to sync". -->
                <TextView
                    android:id="@+id/tv_chalkboard_pending"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textAppearance="?attr/textAppearanceLabelMedium"
                    android:textColor="?attr/colorPrimary"
                    android:visibility="gone"
                    tools:text="2 changes waiting to sync"
                    tools:visibility="visible" />

                <!-- Queued changes that could never sync (the list moved on).
                     Persistent, not a snackbar: the flush may happen while the
                     user is elsewhere in the app. -->
                <LinearLayout
                    android:id="@+id/row_chalkboard_conflict"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <TextView
                        android:id="@+id/tv_chalkboard_conflict"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        android:textColor="?attr/colorError"
                        tools:text="1 change couldn’t sync — the list had moved on:\n• Fix fence" />

                    <Button
                        android:id="@+id/btn_chalkboard_conflict_dismiss"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/chalkboard_conflict_dismiss" />

                </LinearLayout>

                <!-- Status messages only (loading / empty / unavailable); the list
                     itself lives in the RecyclerView below. -->
                <TextView
                    android:id="@+id/tv_chalkboard_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingMultiplier="1.15"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    tools:text="Checking with Alfred…" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_chalkboard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone"
                    tools:itemCount="3"
                    tools:listitem="@layout/item_rolling_todo"
                    tools:visibility="visible" />

                <!-- Add row. Disabled, not hidden, when Alfred can't take writes. -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_chalkboard_add"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/chalkboard_add_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_chalkboard_add"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:imeOptions="actionDone"
                            android:inputType="textCapSentences"
                            android:maxLines="1" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/btn_chalkboard_add"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/chalkboard_add_action" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
