<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipe_refresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Today's Schedule. Hidden wholesale when a tile asked for the to-do only. -->
            <LinearLayout
                android:id="@+id/section_schedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/today_schedule_section"
                    android:textAppearance="?attr/textAppearanceHeadlineSmall" />

                <!-- Per-section status (e.g. showing a cached copy) -->
                <TextView
                    android:id="@+id/tv_schedule_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textAppearance="?attr/textAppearanceLabelMedium"
                    android:visibility="gone"
                    tools:text="Saved copy — Alfred unreachable"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/tv_schedule_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingMultiplier="1.15"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    tools:text="Morning\n• Gym" />

            </LinearLayout>

            <View
                android:id="@+id/section_divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="24dp"
                android:background="?attr/colorOutlineVariant" />

            <!-- Rolling To-Do. Hidden wholesale when a tile asked for the schedule only. -->
            <LinearLayout
                android:id="@+id/section_chalkboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/today_chalkboard_section"
                    android:textAppearance="?attr/textAppearanceHeadlineSmall" />

                <TextView
                    android:id="@+id/tv_chalkboard_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textAppearance="?attr/textAppearanceLabelMedium"
                    android:visibility="gone"
                    tools:text="Saved copy — Alfred unreachable"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/tv_chalkboard_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingMultiplier="1.15"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    tools:text="☐  Plant the bamboo" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
