<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipe_refresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- NestedScrollView, not ScrollView: a wrap_content RecyclerView inside a
         plain ScrollView gets mis-measured and truncates the list (Card AF lesson). -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_inbox_note"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:visibility="gone"
                tools:text="Saved copy — Alfred unreachable"
                tools:visibility="visible" />

            <!-- Offline queue count — "2 captures waiting to sync". -->
            <TextView
                android:id="@+id/tv_inbox_pending_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="?attr/colorPrimary"
                android:visibility="gone"
                tools:text="2 captures waiting to sync"
                tools:visibility="visible" />

            <!-- Captures Alfred refused outright. Persistent, not a snackbar: the
                 flush may happen while the user is elsewhere in the app. -->
            <LinearLayout
                android:id="@+id/row_inbox_refused"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/tv_inbox_refused"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAppearance="?attr/textAppearanceLabelMedium"
                    android:textColor="?attr/colorError"
                    tools:text="1 capture couldn’t be filed:\n• Buy dumbbells" />

                <Button
                    android:id="@+id/btn_inbox_refused_dismiss"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chalkboard_conflict_dismiss" />

            </LinearLayout>

            <!-- Status messages only (loading / empty / unavailable); the captures
                 themselves live in the RecyclerView below. -->
            <TextView
                android:id="@+id/tv_inbox_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:lineSpacingMultiplier="1.15"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                tools:text="Checking with Alfred…" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_inbox_captures"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:visibility="gone"
                tools:itemCount="3"
                tools:listitem="@layout/item_inbox_capture"
                tools:visibility="visible" />

            <!-- Compose row, same shape as the shopping/to-do add rows. The field is
                 multi-line and so has no IME "done" action — a capture is free-form
                 prose, and Enter should break the line rather than send. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="bottom"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_inbox_capture"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/inbox_capture_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_inbox_capture"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top|start"
                        android:inputType="textCapSentences|textMultiLine"
                        android:maxLines="5"
                        android:minLines="1" />

                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/btn_inbox_capture"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/inbox_capture_action" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
